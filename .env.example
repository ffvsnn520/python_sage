# PHP-Sage runtime configuration
# Copy to .env for local runs. Do not commit real secrets.

API_KEY=replace-with-your-dashscope-api-key
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus

# Optional in China mainland. Empty means use HuggingFace default endpoint.
HF_ENDPOINT=https://hf-mirror.com

# Local demo can use memory. Online service should use mysql.
MEMORY_BACKEND=memory

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=php_sage
MYSQL_PASSWORD=replace-with-a-strong-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_DATABASE=php_sage
MYSQL_CHARSET=utf8mb4
